<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:minWidth="500dp"
    android:background="@drawable/dialog_background"
    android:orientation="vertical">

    <!-- Header -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        android:gravity="center_vertical"
        android:padding="16dp"
        android:background="@drawable/settings_section_header_bg">

        <ImageView
            android:layout_width="24dp"
            android:layout_height="24dp"
            android:src="@drawable/ic_epg"
            android:tint="#FEAA2D" />

        <TextView
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:layout_marginStart="12dp"
            android:text="@string/epg_title"
            android:textColor="#FEAA2D"
            android:textSize="18sp"
            android:textStyle="bold" />

        <TextView
            android:id="@+id/tvEpgStationName"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="DAB+ Station"
            android:textColor="@color/dialog_text"
            android:textSize="14sp" />

    </LinearLayout>

    <!-- Aktuelle Sendung -->
    <LinearLayout
        android:id="@+id/layoutCurrentShow"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:padding="16dp"
        android:background="#F5F5F5">

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="@string/epg_now"
            android:textColor="@color/radio_accent"
            android:textSize="11sp"
            android:textStyle="bold"
            android:letterSpacing="0.1" />

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="8dp"
            android:orientation="horizontal"
            android:gravity="center_vertical">

            <!-- Zeit -->
            <TextView
                android:id="@+id/tvCurrentTime"
                android:layout_width="55dp"
                android:layout_height="wrap_content"
                android:text="14:30"
                android:textColor="@color/radio_text_primary"
                android:textSize="15sp"
                android:textStyle="bold" />

            <!-- Titel & Beschreibung -->
            <LinearLayout
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:layout_marginStart="8dp"
                android:orientation="vertical">

                <TextView
                    android:id="@+id/tvCurrentTitle"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:text="Sendungstitel"
                    android:textColor="@color/radio_text_primary"
                    android:textSize="15sp"
                    android:textStyle="bold"
                    android:maxLines="2"
                    android:ellipsize="end" />

                <TextView
                    android:id="@+id/tvCurrentDescription"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="2dp"
                    android:text="Beschreibung"
                    android:textColor="@color/radio_text_secondary"
                    android:textSize="12sp"
                    android:maxLines="2"
                    android:ellipsize="end"
                    android:visibility="gone" />

            </LinearLayout>

            <!-- Endzeit -->
            <TextView
                android:id="@+id/tvCurrentEndTime"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginStart="8dp"
                android:text="bis 15:00"
                android:textColor="@color/radio_text_secondary"
                android:textSize="12sp" />

        </LinearLayout>

        <!-- Progress Bar -->
        <ProgressBar
            android:id="@+id/progressCurrentShow"
            style="@android:style/Widget.ProgressBar.Horizontal"
            android:layout_width="match_parent"
            android:layout_height="4dp"
            android:layout_marginTop="12dp"
            android:max="100"
            android:progress="50"
            android:progressDrawable="@drawable/scan_progress_bar" />

    </LinearLayout>

    <!-- Divider -->
    <View
        android:layout_width="match_parent"
        android:layout_height="1dp"
        android:background="#E0E0E0" />

    <!-- Kommende Sendungen Header -->
    <TextView
        android:id="@+id/tvUpcomingHeader"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:paddingStart="16dp"
        android:paddingEnd="16dp"
        android:paddingTop="12dp"
        android:paddingBottom="6dp"
        android:text="@string/epg_upcoming"
        android:textColor="@color/radio_text_secondary"
        android:textSize="11sp"
        android:textStyle="bold"
        android:letterSpacing="0.1" />

    <!-- Kommende Sendungen Liste -->
    <androidx.recyclerview.widget.RecyclerView
        android:id="@+id/rvUpcomingShows"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:minHeight="100dp"
        android:maxHeight="250dp"
        android:clipToPadding="false"
        android:paddingBottom="8dp"
        android:nestedScrollingEnabled="true" />

    <!-- Empty State (wenn keine EPG-Daten) -->
    <LinearLayout
        android:id="@+id/layoutNoEpg"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:gravity="center"
        android:padding="32dp"
        android:visibility="gone">

        <ImageView
            android:layout_width="48dp"
            android:layout_height="48dp"
            android:src="@drawable/ic_info"
            android:tint="#CCCCCC" />

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginTop="12dp"
            android:text="@string/epg_no_data"
            android:textColor="@color/radio_text_secondary"
            android:textSize="14sp"
            android:gravity="center" />

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginTop="4dp"
            android:text="@string/epg_no_data_desc"
            android:textColor="#999999"
            android:textSize="12sp"
            android:gravity="center" />

    </LinearLayout>

    <!-- Footer -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        android:padding="16dp"
        android:gravity="center_vertical">

        <TextView
            android:id="@+id/tvLastUpdated"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:text="Aktualisiert: --"
            android:textColor="#999999"
            android:textSize="11sp" />

        <TextView
            android:id="@+id/btnCloseEpg"
            android:layout_width="wrap_content"
            android:layout_height="36dp"
            android:paddingStart="24dp"
            android:paddingEnd="24dp"
            android:background="@drawable/button_outline"
            android:gravity="center"
            android:clickable="true"
            android:focusable="true"
            android:text="@string/epg_close"
            android:textColor="#FEAA2D"
            android:textSize="14sp" />

    </LinearLayout>

</LinearLayout>
