<?xml version="1.0" encoding="utf-8"?>
<LinearLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:background="@color/radio_background"
    android:orientation="vertical"
    android:padding="16dp">

    <!-- Header -->
    <TextView
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:text="DAB+ Sendersuche"
        android:textColor="@color/radio_text_primary"
        android:textSize="18sp"
        android:textStyle="bold"
        android:gravity="center"
        android:layout_marginBottom="12dp" />

    <!-- Scan progress -->
    <LinearLayout
        android:id="@+id/dabScanProgressContainer"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:gravity="center"
        android:orientation="vertical"
        android:visibility="gone">

        <ProgressBar
            android:id="@+id/dabScanProgress"
            style="@android:style/Widget.ProgressBar.Horizontal"
            android:layout_width="match_parent"
            android:layout_height="16dp"
            android:max="100"
            android:progressDrawable="@drawable/scan_progress_bar" />

        <TextView
            android:id="@+id/tvDabScanStatus"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginTop="8dp"
            android:text="Suche..."
            android:textColor="@color/radio_text_secondary" />

    </LinearLayout>

    <!-- Station list -->
    <androidx.recyclerview.widget.RecyclerView
        android:id="@+id/dabStationRecycler"
        android:layout_width="match_parent"
        android:layout_height="200dp"
        android:layout_marginTop="12dp"
        android:background="#11000000" />

    <!-- Empty state -->
    <TextView
        android:id="@+id/tvDabEmptyState"
        android:layout_width="match_parent"
        android:layout_height="200dp"
        android:gravity="center"
        android:text="Keine DAB+ Sender gefunden.\nTippe Scan um zu suchen."
        android:textColor="@color/radio_text_secondary"
        android:visibility="visible" />

    <!-- Buttons -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginTop="16dp"
        android:gravity="center"
        android:orientation="horizontal">

        <Button
            android:id="@+id/btnDabScan"
            android:layout_width="wrap_content"
            android:layout_height="48dp"
            android:layout_marginEnd="8dp"
            android:background="@drawable/button_background"
            android:paddingStart="16dp"
            android:paddingEnd="16dp"
            android:text="Scan starten"
            android:textColor="@color/radio_text_primary" />

        <Button
            android:id="@+id/btnDabClose"
            android:layout_width="wrap_content"
            android:layout_height="48dp"
            android:background="@drawable/button_background"
            android:paddingStart="16dp"
            android:paddingEnd="16dp"
            android:text="Schließen"
            android:textColor="@color/radio_text_primary" />

    </LinearLayout>

</LinearLayout>
