<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:minHeight="56dp"
    android:orientation="horizontal"
    android:paddingStart="16dp"
    android:paddingEnd="8dp"
    android:gravity="center_vertical">

    <LinearLayout
        android:layout_width="0dp"
        android:layout_height="wrap_content"
        android:layout_weight="1"
        android:orientation="vertical">

        <TextView
            android:id="@+id/tvPluginName"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:textColor="#333333"
            android:textSize="15sp"
            android:textStyle="bold" />

        <TextView
            android:id="@+id/tvPluginId"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:textColor="#999999"
            android:textSize="11sp" />

    </LinearLayout>

    <TextView
        android:id="@+id/tvBuiltIn"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="built-in"
        android:textColor="#999999"
        android:textSize="12sp"
        android:layout_marginEnd="8dp" />

    <ImageButton
        android:id="@+id/btnExportPlugin"
        android:layout_width="36dp"
        android:layout_height="36dp"
        android:background="?attr/selectableItemBackgroundBorderless"
        android:src="@drawable/ic_share"
        android:scaleType="centerInside"
        android:padding="6dp"
        android:visibility="gone"
        android:contentDescription="Plugin exportieren" />

    <ImageButton
        android:id="@+id/btnDeletePlugin"
        android:layout_width="36dp"
        android:layout_height="36dp"
        android:background="?attr/selectableItemBackgroundBorderless"
        android:src="@drawable/ic_delete"
        android:scaleType="centerInside"
        android:padding="6dp"
        android:visibility="gone"
        android:contentDescription="Plugin löschen" />

</LinearLayout>
