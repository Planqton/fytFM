<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:tools="http://schemas.android.com/tools"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:orientation="vertical"
    android:padding="16dp">

    <TextView
        android:id="@+id/tvPiListTitle"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:text="@string/pi_list_title"
        android:textColor="@color/dialog_text"
        android:textSize="18sp"
        android:textStyle="bold"
        android:layout_marginBottom="8dp" />

    <TextView
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:text="@string/pi_list_subtitle"
        android:textColor="@color/radio_text_secondary"
        android:textSize="12sp"
        android:layout_marginBottom="12dp" />

    <EditText
        android:id="@+id/etPiSearch"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:hint="@string/pi_list_search_hint"
        android:textColor="@color/dialog_text"
        android:textColorHint="@color/radio_text_secondary"
        android:textSize="14sp"
        android:inputType="text"
        android:singleLine="true"
        android:layout_marginBottom="8dp" />

    <TextView
        android:id="@+id/tvPiListCount"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:textColor="@color/radio_text_secondary"
        android:textSize="11sp"
        android:layout_marginBottom="4dp"
        tools:text="68 Einträge" />

    <androidx.recyclerview.widget.RecyclerView
        android:id="@+id/rvPiList"
        android:layout_width="match_parent"
        android:layout_height="0dp"
        android:layout_weight="1"
        android:scrollbars="vertical" />

    <Button
        android:id="@+id/btnPiListClose"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_gravity="end"
        android:layout_marginTop="8dp"
        android:text="@string/close" />

</LinearLayout>
